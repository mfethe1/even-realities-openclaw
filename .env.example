# Telegram Bot API
TELEGRAM_BOT_TOKEN=your_bot_token_here

# OpenAI Whisper (for voice-to-text)
OPENAI_API_KEY=your_openai_key_here

# Twilio (for SMS)
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
TWILIO_PHONE_NUMBER=+13152734843

# Google Workspace (for email + calendar)
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token

# Dexcom Share API
DEXCOM_USERNAME=your_dexcom_username
DEXCOM_PASSWORD=your_dexcom_password
DEXCOM_SHARE_SERVER=https://share2.dexcom.com

# OpenClaw Agent Endpoint (for agent notifications + voice commands)
OPENCLAW_ENDPOINT=http://localhost:4440
